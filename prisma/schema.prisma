datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Contact {
  id            String         @id @default(uuid())
  phone         String         @unique
  name          String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  conversations Conversation[]
  postSession   PostSession?

  @@map("contacts")
}

enum ConversationStatus {
  OPEN
  CLOSED
}

model Conversation {
  id        String             @id @default(uuid())
  contactId String             @map("contact_id")
  status    ConversationStatus @default(OPEN)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  contact   Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@map("conversations")
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

model Message {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  direction      MessageDirection
  type           String           @default("text")
  body           String
  status         String?          // sent, delivered, read, failed
  externalId     String?          @unique @map("external_id") // wamid do WhatsApp
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum PostStep {
  SELECT_FLOW_MODE
  SELECT_BUSINESS_TYPE
  SELECT_FASHION_PRESENTATION
  SELECT_FASHION_MODEL
  SELECT_POST_TYPE
  SELECT_TEMPLATE
  INPUT_COLORS
  INPUT_TITLE
  INPUT_PRICE
  INPUT_IMAGE
  GENERATING
}

model PostSession {
  id                  String   @id @default(uuid())
  contactId           String   @unique @map("contact_id")
  step                PostStep
  businessType        String?  @map("business_type")
  hasHumanModel       Boolean? @map("has_human_model")
  modelProfile        String?  @map("model_profile")
  postType            String?  @map("post_type")
  templateId          String?  @map("template_id")
  colors              String?  @map("colors")
  productTitle        String?  @map("product_title")
  productPrice        String?  @map("product_price")
  productImage        String?  @map("product_image")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  contact             Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("post_sessions")
}
